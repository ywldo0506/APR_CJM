];

function openModal(i) {
  const d = VOC[i];
  document.getElementById('modal-title').textContent = d.name + ' — VOC 상세';
  document.getElementById('modal-neg').innerHTML = d.neg.map(q=>`<div class="modal-q neg">${q}</div>`).join('');
  document.getElementById('modal-pos').innerHTML = d.pos.map(q=>`<div class="modal-q pos">${q}</div>`).join('');
  document.getElementById('overlay').classList.add('on');
}
function closeModal() { document.getElementById('overlay').classList.remove('on'); }
function handleOverlay(e) { if (e.target === document.getElementById('overlay')) closeModal(); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

function toggle(el) { el.classList.toggle('checked'); }

</script>
</body>

<script>
const VOC = [
  { name:"예약", neg:["12시~12시30분 예약을 받지 않아 모임 약속 잡기가 불편했어요. 단체손님 때문에 예약불가라는데 매장엔 빈자리가 많았어요.","예약하고 갔는데 웨이팅이 있었어요. 예약의 의미가 있는 건지 모르겠어요."], pos:["네이버 앱에서 바로 예약할 수 있어서 너무 편리했어요.","사전 예약으로 대기 없이 바로 입장했어요."] },
  { name:"선결제", neg:["입장해서 결제 대기할 때 너무 시장통같아서 짜증났어요. 줄도 없고 중구난방이라 새치기도 당하고.","직원이 포인트 사용법을 몰라 계속 버벅이다가 카드결제로 바꿨어요."], pos:["선결제로 입장이 빠르고 편했어요.","미리 결제하고 들어가니 식사에만 집중할 수 있었어요."] },
  { name:"테이블 착석", neg:["빈자리는 많은데 인원 소화가 안 돼 대기는 넘쳐나고, 막상 입장해도 음식이 모자라 먹질 못하고.","테이블 간격이 너무 좁아서 로봇도 잘 지나가지 못하더라고요."], pos:["뷰 좋은 창가 자리에 앉아서 식사 내내 기분이 좋았어요.","빠르게 자리 안내해 주셔서 기분 좋게 시작했어요."] },
  { name:"샐러드바 — 음식없음", neg:["후식 케이크가 떨어져 채워달라고 요청했지만 안 채워주다가 퇴실할 때쯤 채워놓더라고요.","아이들도 '먹을게 없어'라는 말을 계속 해서 데리고 온 게 미안할 정도였어요."], pos:["메뉴도 다양하고 계속 채워져서 배불리 먹었어요.","다양한 메뉴가 신선하게 유지되어 정말 만족스러웠어요."] },
  { name:"식사 — 맛·품질·청결", neg:["입장하자마자 수저가 다 더러워서 놀랐어요. 음식 퀄리티도 별로고 지저분해서 많이 못 먹었어요.","음식에서 고무 재질의 이물질이 나왔어요. 음식 관리가 필요해 보여요.","모든 음식이 짜요!! 가격대비 음식도 너무 별로라 놀랐어요."], pos:["음식이 전반적으로 맛있고 신선했어요. 만족스러운 식사였습니다.","스테이크 할인받아서 맛있게 먹었어요."] },
